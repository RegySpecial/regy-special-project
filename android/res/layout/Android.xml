<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:columnCount="2"
    android:rowCount="2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.regyspecial.android.MainActivity">
    <TextView
        android:id="@+id/User"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <Button
        android:id="@+id/Play"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play"/>
    <Button
        android:id="@+id/Exit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exit"/>
    <Button
        android:id="@+id/Options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Options"/>
    <Button
        android:id="@+id/Credits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Credits"/>
    <PopupWindow
        android:id="@+id/Play"
    >
        <TextView android:id="@+id/PlayDialogTitle"/>
        <Button
            android:id="@+id/Semplice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semplice"/>
        <Button
            android:id="@+id/Intermedia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intermedia"/>
        <Button
            android:id="@+id/Avanzata"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avanzata"/>
        <Button
            android:id="@+id/Estrema"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estrema">
    </PopupWindow>
</GridLayout>